//- Site header — included by layouts/default.pug
//- Locals: activeNav, headerFixed

-
  var navClass = headerFixed
    ? 'fixed top-0 left-0 right-0 z-30 bg-paper/90 backdrop-blur border-b border-line transition-transform duration-300'
    : 'sticky top-0 z-30 bg-paper/90 backdrop-blur border-b border-line'

header#siteNav(class=navClass)
  div(class='max-w-7xl mx-auto flex items-center justify-between px-5 sm:px-8 lg:px-12 py-4 sm:py-5')
    a.ui-h3.tracking-tight.nav-link(href='/')
      | Template
      span.text-signal °

    nav#siteMenu.ui-mono.text-steel(
      class='hidden md:flex absolute md:static top-full left-0 right-0 flex-col md:flex-row items-stretch md:items-center gap-0 md:gap-8 bg-paper md:bg-transparent border-b md:border-0 border-line px-5 py-4 md:p-0 z-20'
    )
      a.nav-link.transition-colors(
        href='/#capabilities'
        class=`py-3 md:py-0 hover:text-blueprint${activeNav === 'capabilities' ? ' text-ink' : ''}`
      ) Capabilities
      a.nav-link.transition-colors(
        href='/#work'
        class=`py-3 md:py-0 hover:text-blueprint${activeNav === 'work' ? ' text-ink' : ''}`
      ) Work
      a.nav-link.transition-colors(
        href='/#parallax'
        class=`py-3 md:py-0 hover:text-blueprint${activeNav === 'parallax' ? ' text-ink' : ''}`
      ) Parallax
      a.transition-colors(
        href='/typography'
        class=`py-3 md:py-0 hover:text-blueprint${activeNav === 'typography' ? ' text-ink' : ''}`
      ) Typography
      a.transition-colors(
        href='/components'
        class=`py-3 md:py-0 hover:text-blueprint${activeNav === 'components' ? ' text-ink' : ''}`
      ) Components
      a.transition-colors(
        href='/media#parallax'
        class=`py-3 md:py-0 hover:text-blueprint${activeNav === 'media' ? ' text-ink' : ''}`
      ) Media
      a.nav-link.transition-colors(
        href='/#contact'
        class=`py-3 md:py-0 hover:text-blueprint${activeNav === 'contact' ? ' text-ink' : ''}`
      ) Contact

    .flex.items-center.gap-3
      a.nav-link.magnetic.ui-mono.shrink-0.items-center.gap-2.rounded-sm.bg-ink.text-paper.transition-colors(
        href='/#contact'
        class='px-3.5 py-2.5 sm:px-4 sm:py-2.5 hover:bg-blueprint hidden sm:inline-flex'
      )
        | Start a project
        svg(width='12' height='12' viewBox='0 0 12 12' fill='none' aria-hidden='true')
          path(d='M2 6H10M10 6L6.5 2.5M10 6L6.5 9.5' stroke='currentColor' stroke-width='1.4')

      button#navToggle.items-center.justify-center.rounded-sm.border.border-line.px-3.py-2(
        type='button'
        class='inline-flex md:hidden'
        aria-expanded='false'
        aria-controls='siteMenu'
        aria-label='Open menu'
      )
        span.ui-mono.text-ink Menu
